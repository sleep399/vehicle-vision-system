# 服务配置
APP_NAME=车载视觉感知与人机交互系统
SECRET_KEY=change-this-to-a-random-secret-key-in-production
DEBUG=true
HOST=0.0.0.0
PORT=8001
HTTPS_CERTFILE=certs/localhost-cert.pem
HTTPS_KEYFILE=certs/localhost-key.pem

# 数据库
# Windows 身份验证连接本机 SQL Server Express
DATABASE_URL=mssql+pyodbc://@localhost/VehicleVisionDB?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes
DATABASE_ECHO=false

# LLM API（OpenAI 兼容；支持 openai/qwen/deepseek/zhipu/custom）
# 只填写 PROVIDER 和 API_KEY 即可；BASE/MODEL 留空时按厂商自动选择。
# API_KEY 不填时不会访问外网，告警摘要和助手自动使用本地模板。
# 若助手状态栏显示「本地模板降级」，请检查：① LLM_API_KEY 是否有效 ② 网络是否可达 ③ 厂商额度是否充足
# 可用 GET /api/monitor/llm-test 测试连通性。
LLM_PROVIDER=qwen
LLM_API_KEY=
LLM_API_BASE=
LLM_MODEL=
LLM_TIMEOUT=30
LLM_MAX_TOKENS=800

# 邮件通知 (可选)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# Webhook 通知 (企业微信/钉钉/飞书机器人)
WEBHOOK_URL=

# 告警智能体（外发渠道默认关闭）
ALERT_WINDOW_SECONDS=300
ALERT_COOLDOWN_SECONDS=60
ALERT_CONFIG_COOLDOWN_SECONDS=3600
ALERT_TOKEN_WARNING_THRESHOLD=80000
ALERT_TOKEN_CRITICAL_THRESHOLD=95000
ALERT_TOKEN_LIMIT=100000
ALERT_ANOMALY_RATE_THRESHOLD=0.3

# 多路感知场景融合
SCENARIO_WINDOW_SECONDS=30
SCENARIO_CONFLICT_COOLDOWN_SECONDS=45
SCENARIO_SUPPRESS_SECONDS=60
SCENARIO_ADVICE_CACHE_SECONDS=20

ALERT_SSE_ENABLED=true
ALERT_WEBHOOK_ENABLED=false
ALERT_EMAIL_ENABLED=false

# 数据集路径 (相对于项目根目录的上级 database 目录)
CCPD_DATA_PATH=../CCPD-master
CTPGR_DATA_PATH=../ctpgr-pytorch-master
HAGRID_DATA_PATH=../hagrid-master

# AES-256 加密密钥。不要手工填写或提交真实密钥，请运行 python setup_security.py 生成。
AES_KEY=
